# Plantilla para producción en Oracle Cloud (Always Free).
# Copia este archivo a .env.prod EN LA VM y reemplaza con secretos reales.
# .env.prod está en .gitignore — NUNCA commitearlo.
#
# Generar passwords:
#   openssl rand -base64 24    (POSTGRES_PASSWORD, ADMIN_PASSWORD)
#   openssl rand -hex 32       (JWT_SECRET)

# ─── Dominio público ─────────────────────────────────────────────────────────
# Caddy emite el cert Let's Encrypt para este dominio.
# Debe resolver a la IP pública de la VM ANTES de hacer up -d.
DOMAIN=app.tudominio.com

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=REEMPLAZAR_CON_PASSWORD_FUERTE
POSTGRES_DB=cheatsheet

# ─── API (Bun + Hono) ────────────────────────────────────────────────────────
# DATABASE_URL debe coincidir con POSTGRES_USER/PASSWORD/DB de arriba.
DATABASE_URL=postgresql://admin:REEMPLAZAR_CON_PASSWORD_FUERTE@db:5432/cheatsheet

ADMIN_USER=admin
ADMIN_PASSWORD=REEMPLAZAR_CON_PASSWORD_FUERTE
JWT_SECRET=REEMPLAZAR_CON_64_HEX_CHARS
