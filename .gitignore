# -----------------------------
# Global .gitignore (root)
# -----------------------------

# OS/editor noise
.DS_Store
Thumbs.db
.claude/ 
.vscode/
.idea/
*.swp
*.swo

# Logs and debug files
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment and local config (security)
# Nota: no se ignoran .env para facilitar ejecución al clonar.
# Seguridad de producción se ajustará después.

# Node / JS dependencies
node_modules/
.pnp
.pnp.js

# Build outputs and coverage
coverage/
.nyc_output/

# Cache and temp files
.cache/
.tmp/
tmp/

# Runtime data
*.pid

# Docker local overrides and generated files
docker-compose.override.yml
*.tar
